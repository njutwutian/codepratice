useEffect(() => {
 const timer = setInterval(() => {
 console.log(user);
 }, 1000);
 // ✅ 组件卸载时清除定时器
 return () => clearInterval(timer);
}, [user]);
javascript
useEffect(() => {
 setInterval(() => {
 console.log(user);
 }, 1000);
