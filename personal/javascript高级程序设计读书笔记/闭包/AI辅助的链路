const obj = {
 name: 'Alice',
 getName: function() {
 const self = this; // ✅ 把 this 存进变量
 return function() {
 return self.name; // 闭包捕获的是 self（变量）
 };
 }
};
const fn = obj.getName();
console.log(fn()); // 'Alice' ✅
