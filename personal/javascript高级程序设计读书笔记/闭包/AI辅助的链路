const obj = {
 name: 'Alice',
 getName: function() {
 return function() {
 return this.name;
 }.bind(this); // ✅ 把外层 this 绑死到内部函数
 }
};
const fn = obj.getName();
console.log(fn()); // 'Alice' ✅
原理： 箭头函数不创建自己的 this ，它从定义时的外层作用域继承 this 。这正好符合闭包的
“捕获”语义。
