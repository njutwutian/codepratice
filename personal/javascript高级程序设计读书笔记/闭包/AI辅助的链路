// ❌ 危险：DOM 节点引用被闭包死死拽住
function createHandler() {
 const bigDiv = document.getElementById('hugeElement'); // 一个巨大的 DOM 树
 
 // 闭包引用了 bigDiv
 document.getElementById('btn').onclick = function() {
 console.log(bigDiv.id);
 };
 
 // 即使后来页面把 hugeElement 从 DOM 树移除了，
 // 因为闭包还拽着它，这个 DOM 树永远无法被 GC 回收 → 内存泄漏！
}
javascript
// ✅ 安全做法：用完后置空
function createHandler() {
 let bigDiv = document.getElementById('hugeElement');
 const handler = function() {
 console.log(bigDiv.id);
 };
 
 // 执行完关键逻辑后，手动释放
 bigDiv = null; // 切断引用，允许 GC 回收
 return handler;
}
