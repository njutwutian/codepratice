// ❌ 危险：闭包持有大对象
function createHeavyClosure() {
 const hugeArray = new Array(1000000).fill("data"); // 占用大量内存
 const bigObject = { data: hugeArray, ... };
 
 return function() {
 return bigObject; // 闭包持有 bigObject
 };
}
const leak = createHeavyClosure(); // 1MB 数据被保留
// 即使从不调用 leak()，hugeArray 也一直占用内存
