{
  "target": {
    "url": "http://localhost:8080/api/v1/events",
    "method": "POST",
    "headers": {
      "content-type": "application/json",
      "x-source": "SecretPalace"
    },
    "timeoutMs": 5000
  },
  "run": {
    "durationMs": 5000,
    "ratePerSecond": 10,
    "concurrency": 10,
    "maxConcurrency": 1000,
    "maxRetries": 1,
    "retryBaseDelayMs": 200,
    "seed": 20260626,
    "requestTimeoutMs": 5000
  },
  "generator": {
    "templatePath": "templates/event-template.json",
    "strategies": {
      "requestId": {
        "type": "requestId",
        "prefix": "REQBADPAY",
        "width": 6
      },
      "sourceCode": {
        "type": "string",
        "value": "SIMULATOR_A"
      },
      "eventType": {
        "type": "string",
        "value": "DEVICE_STATUS"
      },
      "eventStatus": {
        "type": "string",
        "value": "RECEIVED"
      },
      "eventTime": {
        "type": "nowOffsetIso",
        "offset": "+08:00"
      },
      "payloadCount": {
        "type": "int",
        "min": 0,
        "max": 0
      },
      "payloadSummary": {
        "type": "string",
        "value": "invalid payload count test"
      }
    },
    "staticFields": {}
  },
  "storage": {
    "failedEventsPath": "failures/failed-events.jsonl"
  },
  "report": {
    "outputDir": "reports"
  }
}
